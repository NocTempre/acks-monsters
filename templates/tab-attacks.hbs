<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="attacks">
  <div class="content flexcol">
    <section class="item-list-section">
      <div class="list-header">
        <div class="item__name">{{localize "ACKS-MONSTERS.section.attacks"}}</div>
        {{#if owner}}
        <div class="list-header__controls">
          <a class="item-control" data-tooltip='{{localize "ACKS.items.resetAttacks"}}' data-action="resetAttacks"><i class="fas fa-sync"></i></a>
          <a class="item-control" data-tooltip='{{localize "ACKS.Add"}}' data-action="itemCreate" data-type="weapon"><i class="fas fa-plus"></i></a>
        </div>
        {{/if}}
      </div>
      <p class="acksm-hint">{{localize "ACKS-MONSTERS.hint.attacks"}}</p>
      <ul class="item-list unlist">
        {{#each owned.weapons as |item|}}
        <li class="item draggable" data-item-id="{{item._id}}">
          <div class="item-row">
            <div class="item__pattern" data-action="changePattern" style="--pattern-color: {{item.system.pattern}};" data-tooltip="{{localize 'ACKS.items.pattern'}}"></div>
            <div class="item__icon item-usable" data-action="itemUse"><img src="{{item.img}}" alt="{{item.name}}" class="item__image"/></div>
            <div class="item__text"><a data-action="toggleSummary">{{item.name}}</a></div>
            <div class="acksm-dmg-tag">{{item.system.damage}}</div>
            <div class="item__attack-count">
              <input class="item-input small" type="number" data-name="system.counter.value" data-kind="item" value="{{item.system.counter.value}}" data-dtype="Number" data-tooltip="{{localize 'ACKS.items.roundAttacks'}}"/>
              <span>/</span>
              <input class="item-input small" type="number" data-name="system.counter.max" data-kind="item" value="{{item.system.counter.max}}" data-dtype="Number" data-tooltip="{{localize 'ACKS.items.roundAttacksMax'}}"/>
            </div>
            {{#if ../owner}}
            <div class="item__controls">
              <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </div>
          <div class="item-summary"></div>
        </li>
        {{else}}
        <li class="acksm-empty">{{localize "ACKS-MONSTERS.empty.attacks"}}</li>
        {{/each}}
      </ul>
    </section>
  </div>
</section>
