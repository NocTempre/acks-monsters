<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="ecology">
  <div class="content flexcol acksm-content">

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.economy"}}</legend>
      <div class="flexrow">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.expeditionSpeed"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.expeditionSpeed" value="{{extras.secondary.expeditionSpeed}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.supplyCost"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.supplyCost" value="{{extras.secondary.supplyCost}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.trainingMonths"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.trainingMonths" value="{{extras.secondary.trainingMonths}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.trainingModifier"}}</label>
          <div class="form-fields"><input type="number" name="{{x}}.secondary.trainingModifier" value="{{extras.secondary.trainingModifier}}"/></div></div>
      </div>
      <div class="flexrow">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.brIndividual"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.battleRating.individual" value="{{extras.secondary.battleRating.individual}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.brUnit"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.battleRating.unit" value="{{extras.secondary.battleRating.unit}}"/></div></div>
      </div>
    </fieldset>

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.lifespan"}}
        <label class="acksm-cb"><input type="checkbox" name="{{x}}.secondary.oviparous" {{#if extras.secondary.oviparous}}checked{{/if}}/> {{localize "ACKS-MONSTERS.field.oviparous"}}</label>
      </legend>
      <div class="flexrow acksm-wrap">
        {{#each ages as |age key|}}
        <div class="form-group acksm-narrow"><label>{{localize age.label}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{@root.x}}.secondary.lifespan.{{key}}" value="{{lookup @root.extras.secondary.lifespan key}}"/></div></div>
        {{/each}}
      </div>
      <p class="acksm-hint">{{localize "ACKS-MONSTERS.hint.lifespan"}}</p>
    </fieldset>

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.reproduction"}}</legend>
      <div class="flexrow">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.reproCount"}}</label>
          <div class="form-fields"><input type="text" name="{{x}}.secondary.reproduction.count" value="{{extras.secondary.reproduction.count}}" placeholder="1d4"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.youngType"}}</label>
          <div class="form-fields"><select name="{{x}}.secondary.reproduction.youngType">{{selectOptions choices.youngType selected=extras.secondary.reproduction.youngType localize=true blank=""}}</select></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.interval"}}</label>
          <div class="form-fields"><input type="number" name="{{x}}.secondary.reproduction.interval" value="{{extras.secondary.reproduction.interval}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.intervalUnit"}}</label>
          <div class="form-fields"><select name="{{x}}.secondary.reproduction.intervalUnit">{{selectOptions choices.intervalUnit selected=extras.secondary.reproduction.intervalUnit localize=true blank=""}}</select></div></div>
      </div>
    </fieldset>

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.values"}}
        <a class="acksm-mini" data-action="addRow" data-path="secondary.trainedValue"><i class="fa-solid fa-plus"></i></a></legend>
      <div class="flexrow">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.untrainedAdult"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.untrainedValue.adult" value="{{extras.secondary.untrainedValue.adult}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.untrainedJuvenile"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.untrainedValue.juvenile" value="{{extras.secondary.untrainedValue.juvenile}}"/></div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.untrainedBaby"}}</label>
          <div class="form-fields"><input type="number" step="any" name="{{x}}.secondary.untrainedValue.baby" value="{{extras.secondary.untrainedValue.baby}}"/></div></div>
      </div>
      <div class="acksm-rows">
        {{#each extras.secondary.trainedValue as |row i|}}
        <div class="acksm-row">
          <select name="{{@root.x}}.secondary.trainedValue.{{i}}.role">{{selectOptions @root.choices.trainedRole selected=row.role localize=true}}</select>
          <input type="number" step="any" name="{{@root.x}}.secondary.trainedValue.{{i}}.value" value="{{row.value}}" placeholder="gp"/>
          <input type="text" name="{{@root.x}}.secondary.trainedValue.{{i}}.note" value="{{row.note}}" placeholder="{{localize 'ACKS-MONSTERS.field.note'}}"/>
          <a class="acksm-mini" data-action="removeRow" data-path="secondary.trainedValue" data-index="{{i}}"><i class="fa-solid fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
    </fieldset>

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.encounter"}}</legend>
      <p class="acksm-hint">{{localize "ACKS-MONSTERS.hint.encounter"}}</p>
      <div class="flexrow">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.lairChance"}}</label>
          <div class="form-fields"><input type="number" name="{{x}}.encounter.lairChance" value="{{extras.encounter.lairChance}}" placeholder="%"/></div></div>
        <div class="form-group flex-2"><label>{{localize "ACKS-MONSTERS.field.treasureType"}}</label>
          <div class="form-fields">
            <input type="text" name="system.details.treasure.type" value="{{system.details.treasure.type}}" list="acksm-treasure-types" placeholder="{{localize 'ACKS-MONSTERS.hint.treasureType'}}"/>
            <datalist id="acksm-treasure-types">{{#each choices.treasure as |label key|}}<option value="{{key}}"></option>{{/each}}</datalist>
          </div></div>
      </div>
      <div class="flexrow acksm-enc-grid">
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.dungeonWander"}}</label>
          <div class="form-fields">
            <input type="text" name="{{x}}.encounter.dungeon.wandering.noun" value="{{extras.encounter.dungeon.wandering.noun}}" placeholder="{{localize 'ACKS-MONSTERS.field.noun'}}"/>
            <input type="text" name="{{x}}.encounter.dungeon.wandering.number" value="{{extras.encounter.dungeon.wandering.number}}" placeholder="2d6"/>
          </div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.dungeonLair"}}</label>
          <div class="form-fields">
            <input type="text" name="{{x}}.encounter.dungeon.lair.noun" value="{{extras.encounter.dungeon.lair.noun}}" placeholder="{{localize 'ACKS-MONSTERS.field.noun'}}"/>
            <input type="text" name="{{x}}.encounter.dungeon.lair.number" value="{{extras.encounter.dungeon.lair.number}}" placeholder="6d10"/>
          </div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.wildernessWander"}}</label>
          <div class="form-fields">
            <input type="text" name="{{x}}.encounter.wilderness.wandering.noun" value="{{extras.encounter.wilderness.wandering.noun}}" placeholder="{{localize 'ACKS-MONSTERS.field.noun'}}"/>
            <input type="text" name="{{x}}.encounter.wilderness.wandering.number" value="{{extras.encounter.wilderness.wandering.number}}" placeholder="5d6"/>
          </div></div>
        <div class="form-group"><label>{{localize "ACKS-MONSTERS.field.wildernessLair"}}</label>
          <div class="form-fields">
            <input type="text" name="{{x}}.encounter.wilderness.lair.noun" value="{{extras.encounter.wilderness.lair.noun}}" placeholder="{{localize 'ACKS-MONSTERS.field.noun'}}"/>
            <input type="text" name="{{x}}.encounter.wilderness.lair.number" value="{{extras.encounter.wilderness.lair.number}}" placeholder="6d10"/>
          </div></div>
      </div>
    </fieldset>

    <fieldset>
      <legend>{{localize "ACKS-MONSTERS.section.variants"}}
        <a class="acksm-mini" data-action="addRow" data-path="variants"><i class="fa-solid fa-plus"></i></a></legend>
      <p class="acksm-hint">{{localize "ACKS-MONSTERS.hint.variants"}}</p>
      <div class="acksm-rows">
        {{#each extras.variants as |row i|}}
        <div class="acksm-row">
          <input type="text" name="{{@root.x}}.variants.{{i}}.label" value="{{row.label}}" placeholder="{{localize 'ACKS-MONSTERS.field.variantLabel'}}"/>
          <input type="text" name="{{@root.x}}.variants.{{i}}.uuid" value="{{row.uuid}}" placeholder="{{localize 'ACKS-MONSTERS.field.variantUuid'}}"/>
          <a class="acksm-mini" data-action="removeRow" data-path="variants" data-index="{{i}}"><i class="fa-solid fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
    </fieldset>

  </div>
</section>
