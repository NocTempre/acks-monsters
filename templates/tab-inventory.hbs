<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="inventory">
  <div class="content flexcol">
    <section class="item-list-section">
      <div class="list-header">
        <div class="item__name">{{localize "ACKS-MONSTERS.section.inventory"}}</div>
        {{#if owner}}
        <div class="list-header__controls">
          <a class="item-control" data-tooltip='{{localize "ACKS-MONSTERS.action.addSpoil"}}' data-action="itemCreate" data-type="item"><i class="fas fa-plus"></i> {{localize "ACKS-MONSTERS.field.item"}}</a>
          <a class="item-control" data-tooltip='{{localize "ACKS.Add"}}' data-action="itemCreate" data-type="armor"><i class="fas fa-plus"></i> {{localize "ACKS-MONSTERS.field.armor"}}</a>
        </div>
        {{/if}}
      </div>
      <p class="acksm-hint">{{localize "ACKS-MONSTERS.hint.spoils"}}</p>
      <ul class="item-list unlist">
        {{#each owned.items as |item|}}
        <li class="item draggable" data-item-id="{{item._id}}">
          <div class="item-row">
            <div class="item__icon" data-action="itemShow"><img src="{{item.img}}" alt="{{item.name}}" class="item__image"/></div>
            <div class="item__text"><a data-action="toggleSummary">{{item.name}}</a></div>
            <div class="acksm-inv-meta">{{acksmVal item.system.weight6 0}}/6 st · {{acksmVal item.system.cost 0}} gp</div>
            {{#with item.flags.[acks-monsters] as |mf|}}
              {{#if mf.component}}<div class="acksm-cat-tag">{{localize "ACKS-MONSTERS.item.componentShort"}}</div>{{/if}}
            {{/with}}
            {{#if ../owner}}
            <div class="item__controls">
              <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </div>
          <div class="item-summary"></div>
        </li>
        {{/each}}
        {{#each owned.armors as |item|}}
        <li class="item draggable" data-item-id="{{item._id}}">
          <div class="item-row">
            <div class="item__icon" data-action="itemShow"><img src="{{item.img}}" alt="{{item.name}}" class="item__image"/></div>
            <div class="item__text"><a data-action="toggleSummary">{{item.name}}</a></div>
            <div class="acksm-inv-meta">{{localize "ACKS-MONSTERS.field.armor"}}</div>
            {{#if ../owner}}
            <div class="item__controls">
              <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </div>
          <div class="item-summary"></div>
        </li>
        {{/each}}
        {{#each owned.clothes as |item|}}
        <li class="item draggable" data-item-id="{{item._id}}">
          <div class="item-row">
            <div class="item__icon" data-action="itemShow"><img src="{{item.img}}" alt="{{item.name}}" class="item__image"/></div>
            <div class="item__text"><a data-action="toggleSummary">{{item.name}}</a></div>
            {{#if ../owner}}
            <div class="item__controls">
              <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </div>
          <div class="item-summary"></div>
        </li>
        {{/each}}
        {{#unless owned.items.length}}{{#unless owned.armors.length}}{{#unless owned.clothes.length}}
        <li class="acksm-empty">{{localize "ACKS-MONSTERS.empty.spoils"}}</li>
        {{/unless}}{{/unless}}{{/unless}}
      </ul>
    </section>
  </div>
</section>
