<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="lore">
  <div class="content flexcol acksm-content acksm-lore">
    {{!-- A toggled <prose-mirror> displays its innerHTML while not editing, so
          the stored HTML must be rendered inside the element or the field
          appears blank until toggled. --}}
    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.appearance"}}</label>
    <prose-mirror name="{{x}}.description.appearance" value="{{extras.description.appearance}}" toggled>{{{extras.description.appearance}}}</prose-mirror>

    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.combat"}}</label>
    <prose-mirror name="{{x}}.description.combat" value="{{extras.description.combat}}" toggled>{{{extras.description.combat}}}</prose-mirror>

    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.ecology"}}</label>
    <prose-mirror name="{{x}}.description.ecology" value="{{extras.description.ecology}}" toggled>{{{extras.description.ecology}}}</prose-mirror>

    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.encounterText"}}</label>
    <prose-mirror name="{{x}}.description.encounterText" value="{{extras.description.encounterText}}" toggled>{{{extras.description.encounterText}}}</prose-mirror>

    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.lore"}}</label>
    <prose-mirror name="{{x}}.description.lore" value="{{extras.description.lore}}" toggled>{{{extras.description.lore}}}</prose-mirror>

    <label class="acksm-lore-label">{{localize "ACKS-MONSTERS.desc.notes"}}</label>
    <prose-mirror name="{{x}}.description.notes" value="{{extras.description.notes}}" toggled>{{{extras.description.notes}}}</prose-mirror>
  </div>
</section>
